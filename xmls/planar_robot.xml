<mujoco model="Hopper2D">
    <compiler inertiafromgeom="true" angle="radian"/>
    <option timestep="0.1" integrator="implicit" cone="elliptic"
            solver="Newton" tolerance="1e-10"/>

    <default>
        <geom contype="1" conaffinity="1" condim="3"
              friction="1.0 0.005 0.0001"
              solref="0.005 1"/>
        <joint limited="false" damping="0.05"/>
    </default>

    <asset>
        <material name="ground" rgba="0.2 0.3 0.4 1"/>
        <material name="leg" rgba="0.6 0.6 0.7 1"/>
    </asset>

    <worldbody>
        <!-- Ground -->
        <geom name="floor" type="plane" size="5 5 0.25" material="ground"/>

        <!-- Root floating base -->
        <body name="root" pos="0 0 0.8">
            <joint name="slide_x" type="slide" axis="1 0 0"/>
            <joint name="slide_z" type="slide" axis="0 0 1"/>
            <!-- <joint name="hinge_y" type="hinge" axis="0 1 0"/> -->

            <!-- Torso -->
            <body name="base" pos="0 0 0">
                <geom type="box" size="0.05 0.05 0.1" mass="2.25"
                      material="leg"/>

                <!-- Thigh -->
                <body name="link1" pos="0 0 0">
                    <joint name="hip"
                           type="hinge"
                           axis="0 -1 0"
                           range="-3.14 3.14"/>
                    <geom type="capsule"
                          fromto="0 0 0 0.4 0 0"
                          size="0.04"
                          mass="1.2"/>

                    <!-- Shank -->
                    <body name="link2" pos="0.4 0 0">
                        <joint name="knee"
                               type="hinge"
                               axis="0 -1 0"
                               range="-3.14 3.14"/>
                        <geom type="capsule"
                              fromto="0 0 0 0.4 0 0"
                              size="0.03"
                              mass="0.6"/>

                        <!-- Foot -->
                        <!-- <geom name="foot"
                              type="sphere"
                              pos="0.4 0 0"
                              size="0.04"
                              mass="0.1"/> -->
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="hip_motor" joint="hip"
               ctrlrange="-100 100" ctrllimited="true"/>
        <motor name="knee_motor" joint="knee"
               ctrlrange="-1000 1000" ctrllimited="true"/>
    </actuator>
</mujoco>
