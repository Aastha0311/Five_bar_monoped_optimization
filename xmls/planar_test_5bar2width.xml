<mujoco model="Hopper2D_5bar2width">
	<compiler inertiafromgeom="true" angle="radian"/>
	<option timestep="0.001" integrator="implicit" cone="elliptic" solver="Newton" tolerance="1e-10"/>
	
	<default>
		<geom contype="1" conaffinity="1" condim="3" friction="2 0.005 0.0001" solref="0.005 1"/>
		<joint limited="true" damping="0.1"/>
	</default>
	
	<asset>
		<texture name="skybox" type="skybox" builtin="gradient" rgb1=".4 .6 .8" rgb2="0 0 0" width="800" height="800"/>
		<texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".2 .3 .4"/>
		<material name="ground" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.1"/>
		<material name="leg" rgba="0.5 0.6 0.7 1"/>
	</asset>
	
	<worldbody>
		<!-- Ground -->
		<geom name="floor" type="plane" size="5 5 0.25" material="ground"/>
		
		<!-- Lighting -->
		<light directional="false" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" pos="0 0 2" dir="0 0 -1"/>
		<light mode="targetbodycom" target="base" directional="false" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" pos="0 0 2" dir="0 0 -1"/>
		
		<!-- Cameras -->
		<camera name="fixed" pos="0 -2 1" xyaxes="1 0 0 0 0 1"/>
		<camera name="tracking" mode="trackcom" pos="0 -3 1"/>
		
		<!-- Root body with x and z sliding joints -->
		<body name="root" pos="0 0 0.5">
			<joint name="slide_x" type="slide" axis="1 0 0" range="-100 100"/>
			<joint name="slide_z" type="slide" axis="0 0 1" range="0 10"/>

            <joint name="hinge_y" type="hinge" axis="0 1 0" pos="0 0 0" range="-0.05 0.05" stiffness="0" damping="0.1"/>
			
			<!-- Main hopper body -->
			<body name="base" pos="0 0 0">
				<geom name="torso" type="box" size="0.03 0.03 0.1" mass="2.25" material="leg"/>
				
				<!-- Thigh -->
				<body name="link1" pos="0 0 0" euler="0 0.6751315329370315 0">
					<joint type="hinge" axis="0 -1 0" pos="0 0 0" name="hinge1" limited="true" range="-3.14 3.14" stiffness="0" damping="0.1"/>				
					<geom name="thigh" type="capsule" fromto="0 0 0 0.4 0 0" size="0.01" rgba="0.5 0 0 0.3" mass="1.2702"/>
					
					<!-- Shin -->
					<body name="link2" pos="0.4 0 0" euler="0 1.79132958771573 0">
						<joint type="hinge" axis="0 -1 0" pos="0 0 0" name="hinge2" limited="true" range="-3.14 3.14" stiffness="0" damping="0.1" />					
						<geom name="shank" type="capsule" fromto="0 0 0 0.4 0 0" size="0.01" mass="0.5642"/>
						
						<!-- Foot -->
						
						
					</body>
				</body>
			</body>
		</body>
	</worldbody>
	
	<actuator>
		<motor name="torque1" joint="hinge1" ctrlrange="-33.0 33.0" ctrllimited="true" gear="1"/>
		<motor name="torque2" joint="hinge2" ctrlrange="-44.998799999999996 44.998799999999996" ctrllimited="true" gear="1"/>
	</actuator>
</mujoco>
