<mujoco model="FiveBar2D">

  <compiler inertiafromgeom="true" angle="radian" />
  <option timestep="0.001" integrator="implicit" />

  <default>
    <joint damping="0.1" />
    
    <geom friction="2 0.005 0.0001" contype="1" conaffinity="2" />
    
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".2 .3 .4" />
    <material name="ground" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.1" />
    
  </asset>

  <visual>
    <global offwidth="1920" offheight="1080" />
  </visual>

  <worldbody>

    
    <geom name="floor" type="plane" size="5 5 0.25" material="ground" contype="2" conaffinity="1" />


    <body name="root" pos="0 0 0.4335393962213553">

      <joint name="slide_x" type="slide" axis="1 0 0" />
      <joint name="slide_z" type="slide" axis="0 0 1" />

      <body name="base">

        <geom name="torso" type="box" size="0.14165725795502737 0.05 0.05" rgba="0.2 0.6 1 1" mass="1.706" />

        
        <body name="l1_left" pos="-0.07082862897751369 0 0">

          <joint name="hip_left" type="hinge" axis="0 -1 0" />

          <geom name="thigh_left" type="capsule" fromto="0 0 0 0.31523935376853907 0 0" size="0.03" rgba="1 0 0 1" mass="1.0301701905519094" />

          <body name="l2_left" pos="0.31523935376853907 0 0">

            <joint name="knee_left" type="hinge" axis="0 -1 0" />

            <geom name="shank_left" type="capsule" fromto="0 0 0 0.15738879038567488 0 0" size="0.025" rgba="1 0.5 0 1" mass="0.3642499113471074" />
            <geom name="foot_left" type="sphere" size="0.03" pos="0.15738879038567488 0 0" mass="0" />

            <site name="left_tip" pos="0.15738879038567488 0 0" />

          </body>
        </body>

        
        <body name="l1_right" pos="0.07082862897751369 0 0">

          <joint name="hip_right" type="hinge" axis="0 -1 0" />

          <geom name="thigh_right" type="capsule" fromto="0 0 0 0.31523935376853907 0 0" size="0.03" rgba="0 0 1 1" mass="1.0301701905519094" />

          <body name="l2_right" pos="0.31523935376853907 0 0">

            <joint name="knee_right" type="hinge" axis="0 -1 0" />

            <geom name="shank_right" type="capsule" fromto="0 0 0 0.15738879038567488 0 0" size="0.025" rgba="0 1 1 1" mass="0.3642499113471074" />


            <geom name="foot_right" type="sphere" size="0.03" pos="0.15738879038567488 0 0" mass="0" />

            <site name="right_tip" pos="0.15738879038567488 0 0" />

          </body>
        </body>

      </body>
    </body>
  </worldbody>

  
  <equality>
    <connect site1="left_tip" site2="right_tip" solref="0.01 1" solimp="0.9 0.95 0.001" />
  </equality>

  <actuator>
    <motor name="motor_left" joint="hip_left" ctrlrange="-19.636409554723574 19.636409554723574" />
    <motor name="motor_right" joint="hip_right" ctrlrange="-19.636409554723574 19.636409554723574" />
  </actuator>

</mujoco>