<mujoco model="5bar_simple">
  <compiler angle="radian" inertiafromgeom="true"/>
  <option timestep="0.001" integrator="implicit"/>

  <default>
    <geom rgba="0.7 0.8 0.95 1" density="500"/>
    <joint damping="0.05"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.2 0.2 0.2 1"/>
    <geom name="x_axis" type="cylinder" fromto="0 0 0 0.1 0 0" size="0.001" rgba="1 0 0 1"/>
    <geom name="y_axis" type="cylinder" fromto="0 0 0 0 0.1 0" size="0.001" rgba="0 1 0 1"/>
    <geom name="z_axis" type="cylinder" fromto="0 0 0 0 0 0.1" size="0.001" rgba="0 0 1 1"/>

    <body name="root" pos="0 0 0.6">
      <joint name="slide_x" type="slide" axis="1 0 0" range="-2 2"/>
      <joint name="slide_z" type="slide" axis="0 0 1" range="0 2"/>
      <joint name="hinge_y" type="hinge" axis="0 1 0" range="-0.2 0.2" damping="0.1"/>

      <body name="base" pos="0 0 0">
        <geom name="torso" type="box" size="0.06 0.02 0.02" rgba="0.7 0.8 0.95 1"/>
        <geom name="hip_bar" type="capsule" fromto="-0.06 0 0 0.06 0 0" size="0.01" rgba="0.5 0.6 0.8 1"/>

        <!-- Left chain -->
        <body name="left_upper" pos="-0.06 0 0">
          <joint name="hip_left" type="hinge" axis="0 -1 0" range="-3.14 3.14" damping="0.1"/>
          <geom name="left_upper" type="capsule" fromto="0 0 0 0.25 0 0" size="0.01"/>

          <body name="left_lower" pos="0.25 0 0">
            <joint name="left_knee" type="hinge" axis="0 -1 0" range="-3.14 3.14" damping="0.1"/>
            <geom name="left_lower" type="capsule" fromto="0 0 0 0.25 0 0" size="0.008"/>
            <site name="left_endeff" size="0.004" pos="0.25 0 0" rgba="1 0 0 1"/>
          </body>
        </body>

        <!-- Right chain (mirrored) -->
        <body name="right_upper" pos="0.06 0 0">
          <joint name="hip_right" type="hinge" axis="0 -1 0" range="-3.14 3.14" damping="0.1"/>
          <geom name="right_upper" type="capsule" fromto="0 0 0 -0.25 0 0" size="0.01"/>

          <body name="right_lower" pos="-0.25 0 0">
            <joint name="right_knee" type="hinge" axis="0 -1 0" range="-3.14 3.14" damping="0.1"/>
            <geom name="right_lower" type="capsule" fromto="0 0 0 -0.25 0 0" size="0.008"/>
            <site name="right_endeff" size="0.004" pos="-0.25 0 0" rgba="1 0 0 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <connect name="endeff_link" site1="left_endeff" site2="right_endeff"/>
  </equality>

  <actuator>
    <motor name="hip_left" joint="hip_left" ctrlrange="-44 44"/>
    <motor name="hip_right" joint="hip_right" ctrlrange="-44 44"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0.6 0 -1.0 2.0 -1.0 2.0"/>
  </keyframe>
</mujoco>
