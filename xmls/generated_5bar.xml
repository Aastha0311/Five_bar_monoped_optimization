<mujoco model="5bar">

  <compiler angle="radian" />
  <option integrator="implicit" timestep="0.002" jacobian="dense" cone="elliptic" solver="Newton" tolerance="1e-10" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="160" elevation="-20" />
  </visual>


  <asset>
      <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="512" height="512" />
      <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4" />
      <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2" />
  </asset>

  
  <worldbody>

    <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
    <geom name="floor" size="5 5 0.05" type="plane" material="grid" contype="3" conaffinity="3" />

    <body name="root" pos="0 0 0.6">
      <joint name="slide_x" type="slide" axis="1 0 0" range="-100 100" />
      <joint name="slide_z" type="slide" axis="0 0 1" range="0 10" />
      <joint name="hinge_y" type="hinge" axis="0 1 0" range="-0.05 0.05" damping="0.1" />

      <body name="base" pos="0 0 0">
        <geom name="torso" type="box" size="0.1 0.1 0.14" pos="0 0 0.16" rgba="0.5 0.6 0.7 1" contype="0" conaffinity="0" mass="2.25" />

        
        <body name="mech" quat="0.7071068 0 0.7071068 0">
        <body name="l1_left" pos="0 0 0.0335">
          <joint name="j1_left" type="hinge" pos="0 0 0" axis="0 -1 0" range="-0.785 1.57" frictionloss="0.005" />
          <geom type="capsule" fromto="0 0 0 0.4 0 0" size="0.025" mass="1.2702" rgba="0 0.5 0.5 0.8" contype="0" conaffinity="0" />
          
          <body name="l2_left" pos="0.4 0 0">
            <joint name="j2_left" type="hinge" pos="0 0 0" axis="0 -1 0" frictionloss="0.005" />
            <geom name="l2_left_geom" type="capsule" fromto="0 0 0 0.4 0 -0.0335" size="0.025" mass="0.5642" contype="1" conaffinity="1" margin="0.002" />
            <site name="site_l2_left" pos="0.4 0 -0.0335" />
            
            <body name="pen" pos="0.4 0 -0.0335">
              <joint name="pen_joint" type="hinge" pos="0 0 0" axis="0 -1 0" frictionloss="0.005" />
              <geom name="coupler" type="sphere" size="0.006" pos="0 0 0" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0" mass="0" />
              <geom name="pen_tip" type="cylinder" size="0.001 0.005" pos="0 0 0.004" rgba="0 0 1 0.0" contype="0" conaffinity="0" />
              <geom name="pen_body" type="box" size="0.001 0.001 0.001" pos="0 0 0.008" rgba="0 0 1 0.0" contype="0" conaffinity="0" />
              <site name="site_pen" pos="0 0 0" />
            </body>
          </body>
        </body>  

        <body name="l1_right" pos="0 0 -0.0335">
          <joint name="j1_right" type="hinge" pos="0 0 0" axis="0 -1 0" range="-1.57 0.785" frictionloss="0.005" />
          <geom type="capsule" fromto="0 0 0 0.4 0 0" size="0.025" mass="1.2702" rgba="0.5 0 0.5 0.8" contype="0" conaffinity="0" />
          
          <body name="l2_right" pos="0.4 0 0">
            <joint name="j2_right" type="hinge" pos="0 0 0" axis="0 -1 0" frictionloss="0.005" />
            <geom name="l2_right_geom" type="capsule" fromto="0 0 0 0.4 0 0.0335" size="0.025" mass="0.5642" contype="2" conaffinity="2" margin="0.002" />
            <site name="site_l2_right" pos="0.4 0 0.0335" />
          </body>
        </body>
        </body>
      </body>
    </body>

  </worldbody>


  
  <equality>
    
    <connect site1="site_l2_right" site2="site_pen" solref="0.0001 1" solimp="0.99 0.999 0.001" />
  </equality>

  <contact>
    <exclude body1="base" body2="l1_left" />
    <exclude body1="base" body2="l2_left" />
    <exclude body1="base" body2="l1_right" />
    <exclude body1="base" body2="l2_right" />
    <exclude body1="base" body2="pen" />
    <exclude body1="l2_left" body2="l2_right" />
    <exclude body1="l1_left" body2="l1_right" />
    <exclude body1="l1_left" body2="l2_right" />
    <exclude body1="l1_right" body2="l2_left" />
  </contact>

  
        <actuator>
            <motor name="motor_torque_left" joint="j1_left" ctrlrange="-44 44" />
            <motor name="motor_torque_right" joint="j1_right" ctrlrange="-44 44" />
        </actuator>

        <sensor>
          <touch name="touch_left" site="site_l2_left" />
          <touch name="touch_right" site="site_l2_right" />
        </sensor>

</mujoco>