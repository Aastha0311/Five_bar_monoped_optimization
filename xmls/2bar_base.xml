<mujoco model="2Bar2D">

  <compiler inertiafromgeom="true" angle="radian"/>
  <option timestep="0.001" integrator="implicit"/>

  <default>
    <joint damping="0.1"/>
    <!-- <geom friction="2 0.005 0.0001" contype="1" conaffinity="1"/> -->
    <geom friction="2 0.005 0.0001" contype="1" conaffinity="2"/>
    <!-- <geom contype="1" conaffinity="1"/> -->
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".2 .3 .4"/>
    <material name="ground" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.1"/>
  </asset>

  <worldbody>

    <!-- <geom name="floor"
      type="plane"
      size="5 5 0.25"
      material="ground"/> -->
    <geom name="floor"
      type="plane"
      size="5 5 0.25"
      material="ground"
      contype="2"
      conaffinity="1"/>


    <body name="root" pos="0 0 0.6">

      <joint name="slide_x" type="slide" axis="1 0 0" />
      <joint name="slide_z" type="slide" axis="0 0 1"/>

      <body name="base">

        <geom name="torso"
              type="box"
              size="0.1 0.05 0.05"
              rgba="0.2 0.6 1 1"
              mass="2"/>

        <!-- LEFT HIP (offset in X) -->
       

        <!-- RIGHT HIP (offset in X opposite side) -->
        <body name="link1" pos="0.0 0 0">

          <joint name="hinge1"
                 type="hinge"
                 axis="0 -1 0"/>

          <geom name="thigh"
                type="capsule"
                fromto="0 0 0 0.4 0 0"
                size="0.03"
                rgba="0 0 1 1"
                mass="1"/>

          <body name="link2" pos="0.4 0 0">

            <joint name="hinge2"
                   type="hinge"
                   axis="0 -1 0"/>

            <geom name="shank"
                  type="capsule"
                  fromto="0 0 0 0.4 0 0"
                  size="0.025"
                  rgba="0 1 1 1"
                  mass="0.5"/>


            

          </body>
        </body>

      </body>
    </body>
  </worldbody>

  <!-- Coupler constraint -->
  

  <actuator>
    <motor name="torque1"
           joint="hinge1"
           ctrlrange="-10000 10000"/>
    <motor name="torque2"
           joint="hinge2"
           ctrlrange="-10000 10000"/>
  </actuator>

</mujoco>
